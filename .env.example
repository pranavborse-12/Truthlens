# ====================================================================================
# API KEYS CONFIGURATION - KEEP THESE SECRET, NEVER COMMIT TO GIT
# ====================================================================================
# 
# This file is a template. Copy as .env.local and fill in your actual API keys.
# Do NOT commit .env.local to version control.
#

# GROQ API Keys - Supports up to 4 keys for load distribution
# Get keys from: https://console.groq.com/keys
# You can have: GROQ_API_KEY_1, GROQ_API_KEY_2, GROQ_API_KEY_3, GROQ_API_KEY_4
# System will automatically rotate to next key when approaching daily limit
GROQ_API_KEY_1=your_groq_api_key_here
# GROQ_API_KEY_2=your_second_groq_key_here
# GROQ_API_KEY_3=your_third_groq_key_here
# GROQ_API_KEY_4=your_fourth_groq_key_here

# TAVILY API Keys - Supports up to 2 keys for load distribution
# Get keys from: https://tavily.com/dashboard
TAVILY_API_KEY_1=your_tavily_api_key_here
# TAVILY_API_KEY_2=your_second_tavily_key_here

# Google Gemini API Key - BACKEND ONLY (NOT exposed to frontend)
# Get key from: https://makersuite.google.com/app/apikey
# ⚠️ IMPORTANT: Use GEMINI_API_KEY, NOT NEXT_PUBLIC_GEMINI_API_KEY
# The NEXT_PUBLIC_ prefix would expose your key to the browser (security risk)
GEMINI_API_KEY=your_gemini_api_key_here

# ====================================================================================
# APPLICATION CONFIGURATION
# ====================================================================================

# Application URL - used for self-referential links and API callbacks
APP_URL=http://localhost:3000

# API Rate Limits - requests allowed per 24 hours
# Adjust based on your subscription plan limits
GROQ_DAILY_LIMIT=1000
TAVILY_DAILY_LIMIT=500

# Environment - impacts error handling and logging
NODE_ENV=development

